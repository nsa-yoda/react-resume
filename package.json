{
  "name": "react-resume",
  "version": "1.1.0",
  "private": true,
  "dependencies": {
    "normalize-url": "^9.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "yaml": "^2.9.0"
  },
  "scripts": {
    "dev": "vite --port 3000",
    "start": "vite --port 3000",
    "build": "vite build --outDir build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate-data": "node scripts/validate-data.mjs",
    "migrate-data": "node scripts/migrate-data.mjs",
    "migrate-data:yaml": "node scripts/migrate-data.mjs yaml",
    "migrate-data-to-v2": "node scripts/migrate-data.mjs json",
    "migrate-data-to-v2:yaml": "node scripts/migrate-data.mjs yaml",
    "import:json-resume": "node scripts/import-json-resume.mjs",
    "prepare": "husky install"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.63.0",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
